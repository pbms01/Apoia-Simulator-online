{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "apoia-simulator-online",
  "version": 2,
  "builds": [
    {
      "src": "web/client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/web/client/dist/index.html" }
  ]
}
