{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "apoia-simulator-online",
  "installCommand": "npm install && cd web/client && npm install",
  "buildCommand": "cd web/client && npx vite build",
  "outputDirectory": "web/client/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
