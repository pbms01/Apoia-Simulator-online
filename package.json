{
  "name": "apoia-simulator-online",
  "version": "2.0.0",
  "description": "Simulador online do APOIA - Sistema de IA Juridica do TRF2",
  "type": "module",
  "main": "dist/web/server/index.js",
  "scripts": {
    "dev:server": "tsx watch web/server/index.ts",
    "dev:client": "npm run dev --prefix web/client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "npm run build --prefix web/client",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/web/server/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "tsc --noEmit -p tsconfig.server.json"
  },
  "keywords": [
    "apoia",
    "trf2",
    "juridico",
    "ia",
    "llm",
    "judicial"
  ],
  "author": "TRF2",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^4.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "pdfjs-dist": "^4.9.155",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^1.4.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
